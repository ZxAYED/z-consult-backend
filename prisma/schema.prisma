generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  // url      = env("DATABASE_URL")
}

//
// ENUMS
//
enum StaffType {
  DOCTOR
  CONSULTANT
  SUPPORT_AGENT
  OTHER
}

enum StaffAvailability {
  AVAILABLE
  ON_LEAVE
}

enum AppointmentStatus {
  WAITING // in queue (no staff yet)
  SCHEDULED
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum QueueStatus {
  ACTIVE
  ASSIGNED
  CANCELLED
}

enum LogAction {
  APPOINTMENT_CREATED
  APPOINTMENT_UPDATED
  APPOINTMENT_CANCELLED
  QUEUE_JOINED
  QUEUE_ASSIGNED
  STAFF_STATUS_CHANGED
  SERVICE_CREATED
  STAFF_CREATED
}

enum Role {
  ADMIN
}

//
// MODELS
//
model User {
  id                String    @id @default(cuid())
  email             String    @unique
  passwordHash      String
  name              String?
  refreshTokenHash  String?
  resetOtp          String?
  resetOtpExpiresAt DateTime?
  role              Role      @default(ADMIN)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Staff {
  id            String            @id @default(cuid())
  name          String
  type          StaffType
  dailyCapacity Int               @default(5)
  availability  StaffAvailability @default(AVAILABLE)

  contactEmail String?
  contactPhone String?

  appointments Appointment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([type])
  @@index([availability])
}

model Service {
  id                String    @id @default(cuid())
  name              String
  durationMinutes   Int
  requiredStaffType StaffType

  appointments Appointment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([requiredStaffType])
}

model Appointment {
  id            String  @id @default(cuid())
  customerName  String
  customerEmail String?
  customerPhone String?

  serviceId String
  service   Service @relation(fields: [serviceId], references: [id])

  staffId String?
  staff   Staff?  @relation(fields: [staffId], references: [id])

  startAt DateTime
  endAt   DateTime

  status AppointmentStatus @default(SCHEDULED)

  queueItem QueueItem?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([startAt])
  @@index([staffId])
  @@index([status])
}

model QueueItem {
  id            String      @id @default(cuid())
  appointmentId String      @unique
  appointment   Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)

  status   QueueStatus @default(ACTIVE)
  queuedAt DateTime    @default(now())

  @@index([status, queuedAt])
}

model ActivityLog {
  id        String    @id @default(cuid())
  action    LogAction
  message   String
  metadata  Json?     // Flexible metadata
  createdAt DateTime  @default(now())

  @@index([action])
  @@index([createdAt])
}
